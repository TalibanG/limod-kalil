# build artifacts — the .exe goes to GitHub Releases, not the repo
build/
dist/
*.zip
*.spec.bak

# user data & secrets — never publish
data/
*.log

# python
__pycache__/
*.pyc
.venv/
venv/

# source code — kept private; only the compiled Release is distributed publicly
*.py
*.spec
*.bat
*.ico
static/

# internal docs — keep only the public README
*.md
!README.md
